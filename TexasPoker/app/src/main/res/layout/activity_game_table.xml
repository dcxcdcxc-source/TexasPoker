<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnLeave"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"/>

        <TextView
            android:id="@+id/tvTableName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="德州扑克"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tvBlinds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25/50"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="翻前"
            android:textColor="#00CCFF"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- 牌桌主视图（自定义View） -->
    <FrameLayout
        android:id="@+id/tableContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/infoBar"/>

    <!-- 信息栏 -->
    <LinearLayout
        android:id="@+id/infoBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/myCardsPanel">

        <TextView
            android:id="@+id/tvPot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="底池: 0"
            android:textColor="@color/gold"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMyChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="筹码: 10K"
            android:textColor="#00FF88"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="30s"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 玩家手牌面板 -->
    <LinearLayout
        android:id="@+id/myCardsPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/actionPanel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp">

        <com.texaspoker.game.ui.table.CardView
            android:id="@+id/cardView1"
            android:layout_width="64dp"
            android:layout_height="90dp"
            android:layout_marginEnd="6dp"/>

        <com.texaspoker.game.ui.table.CardView
            android:id="@+id/cardView2"
            android:layout_width="64dp"
            android:layout_height="90dp"/>
    </LinearLayout>

    <!-- 赢钱动画文字 -->
    <TextView
        android:id="@+id/tvWinAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+10K"
        android:textSize="36sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 消息文字 -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#CCFFFFFF"
        android:background="#88000000"
        android:padding="6dp"
        app:layout_constraintBottom_toTopOf="@id/infoBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"/>

    <!-- 操作面板 -->
    <LinearLayout
        android:id="@+id/actionPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#DD000000"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 加注滑块 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvBetAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="加注: 100"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderBet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="100"
                android:valueTo="10000"
                android:value="100"
                android:stepSize="50"/>
        </LinearLayout>

        <!-- 操作按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnFold"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="弃牌"
                android:textSize="14sp"
                android:backgroundTint="#C62828"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnCheck"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="过牌"
                android:textSize="14sp"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="4dp"
                android:visibility="visible"/>

            <Button
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="跟注"
                android:textSize="14sp"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="4dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnRaise"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="加注"
                android:textSize="14sp"
                android:backgroundTint="#E65100"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnAllIn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="全下"
                android:textSize="14sp"
                android:backgroundTint="#4A148C"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
