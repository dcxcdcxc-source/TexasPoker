<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme -->
    <style name="Theme.TexasPoker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/active_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_card</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.TexasPoker.Body</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.TexasPoker.Splash" parent="Theme.TexasPoker">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.TexasPoker.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Button -->
    <style name="Widget.TexasPoker.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
